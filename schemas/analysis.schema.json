{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "analysis.schema.json",
  "type": "object",
  "required": ["entries", "sources"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "summary", "sources"],
        "properties": {
          "topic":   { "type": "string" },
          "summary": { "type": "string", "minLength": 1 },
          "sources": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "required": ["source", "url", "retrieved_at"],
              "properties": {
                "source":         { "type": "string" },
                "url":            { "type": "string", "format": "uri" },
                "retrieved_at":   { "type": "string", "format": "date-time" },
                "archive_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "excerpt":        { "type": "string" },
                "summary":        { "type": "string" }
              },
              "anyOf": [
                { "required": ["excerpt"] },
                { "required": ["summary"] }
              ],
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "url", "retrieved_at"],
        "properties": {
          "source":         { "type": "string" },
          "url":            { "type": "string", "format": "uri" },
          "retrieved_at":   { "type": "string", "format": "date-time" },
          "archive_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
